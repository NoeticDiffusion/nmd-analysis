{
    "terminal.integrated.defaultProfile.windows": "Command Prompt (venv)",
    "terminal.integrated.profiles.windows": {
        "Command Prompt (venv)": {
            "path": "C:\\Windows\\System32\\cmd.exe",
            "args": [
                "/K",
                "${workspaceFolder}\\.venv\\Scripts\\activate.bat"
            ],
            "icon": "terminal-cmd"
        },
        "PowerShell (venv)": {
            "source": "PowerShell",
            "args": [
                "-NoExit",
                "-NoLogo",
                "-ExecutionPolicy",
                "Bypass",
                "-Command",
                "& \"${workspaceFolder}\\.venv\\Scripts\\Activate.ps1\""
            ],
            "icon": "terminal-powershell"
        }
    }
}
